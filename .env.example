# 以下端口为备用；优先读取桌面端 ~/.ibkr-order-tool/settings.json 的 account_mode
PAPER_PORT=7497
LIVE_PORT=7496
TWS_PORT=7497
CLIENT_ID=1
FLEX_TOKEN=YOUR_FLEX_TOKEN
FLEX_QUERY_ID=YOUR_FLEX_QUERY_ID
# Flex Query ID 轮询池（防限流，逗号分隔，默认 3 个）
FLEX_QUERY_IDS=1562873,1568627,1568630
# ====== 网络代理（Clash Verge Rev）======
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# ====== 风控参数 ======
RISK_MAX_DRAWDOWN_GREEN=0.05
RISK_MAX_DRAWDOWN_YELLOW=0.10
RISK_PCT_PER_TRADE=0.003
MAX_POSITION_SIZE_PCT=0.40
MAX_STOP_PCT=0.03
MAX_DAILY_TRADES=3
MAX_OVERNIGHT_RISK_PCT=0.015

# ====== RiskCore 定稿契约 ======
MIN_CUSHION=0.10
MIN_RISK_PER_SHARE=1.0
MIN_ENTRY_PRICE=5.0
MATERIAL_DEPLETION_PCT=0.05
AVG_COST_DRIFT_PCT=0.20
MAX_SYNC_GAP_DAYS=7
IN_FLIGHT_TTL_SEC=30
POSITION_SYNC_WARMUP_SEC=3
ALLOWED_CURRENCY=USD
ALLOWED_SEC_TYPE=STK
# 与运行 TWS 的 OS 本地时区一致（空=自动用本机）；例 Asia/Shanghai
IB_EXEC_TIMEZONE=
ALLOWED_ENTRY_ORDER_TYPES=LMT,STP LMT,STP

# ====== 数据库 ======
DB_PATH=risk_manager.db
DB_TIMEOUT=10.0
TRADING_TZ=America/New_York

# ====== 引擎开关 ======
# （EOD 10EMA 狙击手已移除；夜间靠 TWS 物理止损）

# ====== 硬编码参数提取 ======
THRESHOLD_3R=3.0
FORCE_CONFESSION_HOUR=23
LOG_LEVEL=INFO