MY_TELEGRAM_CHAT_ID=123456789
TG_BOT_TOKEN=YOUR_TG_TOKEN
# 以下端口为备用；Bot 优先读取桌面端 ~/.ibkr-order-tool/settings.json 的 account_mode
PAPER_PORT=7497
LIVE_PORT=7496
TWS_PORT=7497
CLIENT_ID=1
FLEX_TOKEN=YOUR_FLEX_TOKEN
FLEX_QUERY_ID=YOUR_FLEX_QUERY_ID
NOTION_TOKEN=YOUR_NOTION_TOKEN
NOTION_DATABASE_ID=YOUR_NOTION_DATABASE_ID

# ====== 风控参数 ======
RISK_MAX_DRAWDOWN_GREEN=0.05
RISK_MAX_DRAWDOWN_YELLOW=0.10
RISK_PCT_PER_TRADE=0.003
MAX_POSITION_SIZE_PCT=0.40
MAX_STOP_PCT=0.03
MAX_DAILY_TRADES=3
MAX_OVERNIGHT_RISK_PCT=0.015

# ====== 数据库 ======
DB_PATH=risk_manager.db
DB_TIMEOUT=10.0
TRADING_TZ=America/New_York

# ====== 引擎开关 ======
ENABLE_EOD_SNIPER=false

# ====== 硬编码参数提取 ======
THRESHOLD_3R=3.0
EMA_PERIOD=10
FORCE_CONFESSION_HOUR=23
LOG_LEVEL=INFO
